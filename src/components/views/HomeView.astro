---
import Base from "../../layouts/Base.astro";
import { calculators } from "../../engine/registry";
import { ui } from "../../i18n/ui";
import { calcContent } from "../../i18n/content";
import { localizePath, type Locale } from "../../i18n/config";

interface Props { locale?: Locale; }
const { locale = "en" } = Astro.props;
const t = ui(locale);
---

<Base
	title={`${t.brand} — ${t.tagline}`}
	description={t.heroLede}
	path="/"
	locale={locale}
>
	<section class="hero">
		<h1>{t.heroTitle}</h1>
		<p class="lede">{t.heroLede}</p>
	</section>

	<div class="card-grid">
		{calculators.map((c) => (
			<a class="calc-card" href={localizePath(`/${c.slug}`, locale)}>
				<h3>{calcContent(c.id, locale).title ?? c.title}</h3>
				<p>{calcContent(c.id, locale).description ?? c.description}</p>
			</a>
		))}
	</div>
</Base>
