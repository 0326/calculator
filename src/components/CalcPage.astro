---
import Base from "../layouts/Base.astro";
import JsonLd from "./JsonLd.astro";
import AdSlot from "./AdSlot.astro";
import Calculator from "./Calculator.tsx";
import { bySlug } from "../engine/registry";
import type { CalculatorDef, InputValues } from "../engine/types";

interface Crumb { name: string; url: string; }
interface VariantLink { slug: string; label: string; }

interface Props {
	def: CalculatorDef;
	title: string;
	description: string;
	path: string;
	crumbs: Crumb[];
	initialValues?: Partial<InputValues>;
	/** Variant-specific lede paragraph (anti-HCU unique copy). */
	intro?: string;
	variants?: VariantLink[];
}

const { def, title, description, path, crumbs, initialValues, intro, variants = [] } = Astro.props;
const url = new URL(path, Astro.site ?? "https://example.com").href;
const related = def.related.map((slug) => bySlug(slug)).filter(Boolean) as CalculatorDef[];
const embedSnippet = `<iframe src="${new URL("/embed/" + def.id, Astro.site ?? "https://example.com").href}" width="100%" height="640" style="border:1px solid #e2e8f0;border-radius:12px" loading="lazy" title="${def.title}"></iframe>`;
---

<Base title={title} description={description} path={path}>
	<JsonLd slot="head" def={def} url={url} crumbs={crumbs} />

	<nav class="breadcrumbs" aria-label="Breadcrumb">
		{crumbs.map((c, i) => (
			<>
				{i > 0 && <span> › </span>}
				{i < crumbs.length - 1 ? <a href={c.url}>{c.name}</a> : <span>{c.name}</span>}
			</>
		))}
	</nav>

	<section class="hero">
		<h1>{title}</h1>
		<p class="lede">{intro ?? def.description}</p>
	</section>

	<!-- Tool first, always above any ad (PRD §8/§10.1) -->
	<div class="calc-shell">
		<Calculator client:visible calculatorId={def.id} initialValues={initialValues} />
	</div>

	<AdSlot format="leaderboard" />

	<div class="prose">
		<h2>How this works</h2>
		<p>{def.content.intro}</p>

		{variants.length > 0 && (
			<>
				<h2>Popular variants</h2>
				<div class="variant-links">
					{variants.map((v) => <a href={v.slug}>{v.label}</a>)}
				</div>
			</>
		)}

		<h2>Frequently asked questions</h2>
		<div class="faq">
			{def.content.faq.map((f) => (
				<details>
					<summary>{f.q}</summary>
					<p>{f.a}</p>
				</details>
			))}
		</div>

		{related.length > 0 && (
			<>
				<h2>Related calculators</h2>
				<div class="related-grid">
					{related.map((r) => (
						<a class="calc-card" href={`/${r.slug}`}>
							<h3>{r.title}</h3>
							<p>{r.description}</p>
						</a>
					))}
				</div>
			</>
		)}

		<div class="embed-cta">
			<strong>Put this calculator on your site</strong>
			<p style="margin:6px 0 0;font-size:14px;color:var(--ink-faint)">Free, responsive, and always up to date. Copy the embed code:</p>
			<code>{embedSnippet}</code>
		</div>

		<p class="disclaimer">{def.content.disclaimer}</p>
	</div>

	<AdSlot format="rectangle" />
</Base>
