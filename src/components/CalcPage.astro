---
import Base from "../layouts/Base.astro";
import JsonLd from "./JsonLd.astro";
import AdSlot from "./AdSlot.astro";
import Calculator from "./Calculator.tsx";
import { bySlug } from "../engine/registry";
import type { CalculatorDef, InputValues, Category } from "../engine/types";
import { ui } from "../i18n/ui";
import { calcContent } from "../i18n/content";
import { localizePath, type Locale } from "../i18n/config";

interface VariantLink { slug: string; label: string; }

interface Props {
	def: CalculatorDef;
	locale?: Locale;
	/** Bare path WITHOUT locale prefix. */
	path: string;
	initialValues?: Partial<InputValues>;
	/** Variant headline override (e.g. "15-Year Mortgage"). */
	headline?: string;
	/** Variant-specific lede / unique copy (anti-HCU). */
	intro?: string;
	variants?: VariantLink[];
	/** Extra breadcrumb for variant pages. */
	extraCrumb?: { name: string; url: string };
}

const {
	def,
	locale = "en",
	path,
	initialValues,
	headline,
	intro,
	variants = [],
	extraCrumb,
} = Astro.props;

const t = ui(locale);
const c = calcContent(def.id, locale);
const locTitle = c.title ?? def.title;
const locDesc = c.description ?? def.description;

const headTitle = headline ? `${headline} · ${t.brand}` : `${locTitle} · ${t.brand}`;
const metaDesc = intro ?? locDesc;
const lede = intro ?? locDesc;

const categoryLabel: Record<Category, string> = {
	mortgage: t.navMortgage,
	loan: t.navLoan,
	retirement: t.navRetirement,
	tax: t.navTax,
	investment: t.navRetirement,
};

const crumbs = [
	{ name: t.home, url: localizePath("/", locale) },
	{ name: categoryLabel[def.category], url: localizePath(`/calculators/${def.category}`, locale) },
	{ name: locTitle, url: localizePath(`/${def.slug}`, locale) },
	...(extraCrumb ? [extraCrumb] : []),
];

const url = new URL(localizePath(path, locale), Astro.site ?? "https://example.com").href;
const related = def.related.map((slug) => bySlug(slug)).filter(Boolean) as CalculatorDef[];
const embedSnippet = `<iframe src="${new URL("/embed/" + def.id, Astro.site ?? "https://example.com").href}" width="100%" height="640" style="border:1px solid #e2e8f0;border-radius:12px" loading="lazy" title="${locTitle}"></iframe>`;

const faq = c.faq ?? def.content.faq;
const introProse = c.intro ?? def.content.intro;
const disclaimer = c.disclaimer ?? def.content.disclaimer;
---

<Base title={headTitle} description={metaDesc} path={path} locale={locale}>
	<JsonLd slot="head" def={def} url={url} crumbs={crumbs} locale={locale} title={locTitle} description={locDesc} faq={faq} />

	<nav class="breadcrumbs" aria-label="Breadcrumb">
		{crumbs.map((cr, i) => (
			<>
				{i > 0 && <span> › </span>}
				{i < crumbs.length - 1 ? <a href={cr.url}>{cr.name}</a> : <span>{cr.name}</span>}
			</>
		))}
	</nav>

	<section class="hero">
		<h1>{headline ?? locTitle}</h1>
		<p class="lede">{lede}</p>
	</section>

	<!-- Tool first, always above any ad (PRD §8/§10.1) -->
	<div class="calc-shell">
		<Calculator client:idle calculatorId={def.id} initialValues={initialValues} locale={locale} />
	</div>

	<AdSlot format="leaderboard" />

	<div class="prose">
		<h2>{t.howItWorks}</h2>
		<p>{introProse}</p>

		{variants.length > 0 && (
			<>
				<h2>{t.popularVariants}</h2>
				<div class="variant-links">
					{variants.map((v) => <a href={v.slug}>{v.label}</a>)}
				</div>
			</>
		)}

		<h2>{t.faqHeading}</h2>
		<div class="faq">
			{faq.map((f) => (
				<details>
					<summary>{f.q}</summary>
					<p>{f.a}</p>
				</details>
			))}
		</div>

		{related.length > 0 && (
			<>
				<h2>{t.relatedHeading}</h2>
				<div class="related-grid">
					{related.map((r) => (
						<a class="calc-card" href={localizePath(`/${r.slug}`, locale)}>
							<h3>{calcContent(r.id, locale).title ?? r.title}</h3>
							<p>{calcContent(r.id, locale).description ?? r.description}</p>
						</a>
					))}
				</div>
			</>
		)}

		<div class="embed-cta">
			<strong>{t.embedHeading}</strong>
			<p style="margin:6px 0 0;font-size:14px;color:var(--ink-faint)">{t.embedDesc}</p>
			<code>{embedSnippet}</code>
		</div>

		<p class="disclaimer">{disclaimer}</p>
	</div>

	<AdSlot format="rectangle" />
</Base>
