---
// Embeddable widget shell (PRD §10.2). Minimal chrome, noindex, reuses the same
// engine + island. Each embed on a partner site = a branded backlink.
import "../../styles/global.css";
import Calculator from "../../components/Calculator.tsx";
import { calculators, byId } from "../../engine/registry";

export function getStaticPaths() {
	return calculators.map((c) => ({ params: { id: c.id } }));
}

const def = byId(Astro.params.id as string)!;
const home = Astro.site?.href ?? "https://example.com/";
---

<!doctype html>
<html lang="en" data-calc-id={def.id}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="robots" content="noindex,follow" />
		<title>{def.title} — FinCalc widget</title>
		<style>
			body { margin: 0; background: #fff; padding: 12px; }
			.embed-foot { text-align: right; font-size: 12px; margin-top: 8px; color: var(--ink-faint); }
		</style>
	</head>
	<body>
		<Calculator client:load calculatorId={def.id} compact />
		<p class="embed-foot">
			Powered by <a href={home} target="_blank" rel="noopener">FinCalc</a>
		</p>
		{/* Analytics: record that this embed widget was viewed. calculatorId only — no PII. */}
		<script>
			import { track } from "../../lib/analytics";
			const calcId = document.documentElement.dataset.calcId;
			if (calcId) track("embed_view", { calculatorId: calcId });
		</script>
	</body>
</html>
