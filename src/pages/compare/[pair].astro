---
import CompareView from "../../components/views/CompareView.astro";
import { COMPARES } from "../../content/compares";

export function getStaticPaths() {
	return COMPARES.map((spec) => ({ params: { pair: spec.pair }, props: { spec } }));
}

const { spec } = Astro.props;
---
<CompareView locale="en" spec={spec} />
