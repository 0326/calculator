---
import CalcPage from "../components/CalcPage.astro";
import { calculators } from "../engine/registry";
import { localizePath } from "../i18n/config";
import type { CalculatorDef } from "../engine/types";

export function getStaticPaths() {
	return calculators.map((def) => ({ params: { slug: def.slug }, props: { def } }));
}

const { def } = Astro.props as { def: CalculatorDef };
const variants = def.inputs
	.flatMap((f) => f.presets ?? [])
	.map((p) => ({ slug: localizePath(`/${def.slug}/${p.id}`, "en"), label: p.label }));
---

<CalcPage def={def} locale="en" path={`/${def.slug}`} variants={variants} />
