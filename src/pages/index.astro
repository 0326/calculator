---
import Base from "../layouts/Base.astro";
import { calculators } from "../engine/registry";
---

<Base
	title="FinCalc — Free Financial Calculators, Beautifully Visualized"
	description="Mortgage, loan, retirement, and tax calculators with the clearest interactive charts on the web. 100% free, no sign-up, and every calculation runs privately in your browser."
	path="/"
>
	<section class="hero">
		<h1>Financial calculators that actually show you the math</h1>
		<p class="lede">
			Interactive, beautifully charted, and completely private — every number is computed in
			your browser and never sent anywhere. No sign-up, no paywall, no dark patterns.
		</p>
	</section>

	<div class="card-grid">
		{calculators.map((c) => (
			<a class="calc-card" href={`/${c.slug}`}>
				<h3>{c.title}</h3>
				<p>{c.description}</p>
			</a>
		))}
	</div>

	<div class="prose">
		<h2>Why FinCalc</h2>
		<p>
			Most calculators give you a single number and an ugly table. FinCalc shows you how
			principal and interest shift over time, how extra payments change your payoff date, and how
			a range of returns could play out — with charts you can actually explore on any device.
		</p>
		<h2>Private by design</h2>
		<p>
			There are no accounts and no servers crunching your finances. Everything runs locally, so
			your numbers stay on your device. That is a privacy promise and a compliance safeguard in
			one. For general information only — not financial, investment, or tax advice.
		</p>
	</div>
</Base>
