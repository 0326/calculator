---
import CalcPage from "../../components/CalcPage.astro";
import { calculators } from "../../engine/registry";
import { PREFIXED_LOCALES, LOCALE_META, localizePath, type Locale } from "../../i18n/config";
import type { CalculatorDef } from "../../engine/types";

export function getStaticPaths() {
	return PREFIXED_LOCALES.flatMap((l) =>
		calculators.map((def) => ({
			params: { locale: LOCALE_META[l].prefix, slug: def.slug },
			props: { def, locale: l },
		})),
	);
}

const { def, locale } = Astro.props as { def: CalculatorDef; locale: Locale };
const variants = def.inputs
	.flatMap((f) => f.presets ?? [])
	.map((p) => ({ slug: localizePath(`/${def.slug}/${p.id}`, locale), label: p.label }));
---

<CalcPage def={def} locale={locale} path={`/${def.slug}`} variants={variants} />
