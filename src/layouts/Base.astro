---
import "../styles/global.css";
import LanguagePicker from "../components/LanguagePicker.astro";
import CookieConsent from "../components/CookieConsent.astro";
import { ui } from "../i18n/ui";
import {
	LOCALES,
	LOCALE_META,
	DEFAULT_LOCALE,
	localizePath,
	type Locale,
} from "../i18n/config";

interface Props {
	title: string;
	description: string;
	/** Bare path WITHOUT locale prefix, e.g. "/mortgage-calculator". */
	path?: string;
	locale?: Locale;
	noindex?: boolean;
}

const { title, description, path = "/", locale = "en", noindex = false } = Astro.props;
const site = Astro.site ?? new URL("https://example.com");
const t = ui(locale);
const meta = LOCALE_META[locale];

const canonical = new URL(localizePath(path, locale), site).href;
const alternates = LOCALES.map((l) => ({
	hreflang: LOCALE_META[l].htmlLang,
	href: new URL(localizePath(path, l), site).href,
}));
const xDefault = new URL(localizePath(path, DEFAULT_LOCALE), site).href;

const nav = [
	{ href: localizePath("/mortgage-calculator", locale), label: t.navMortgage },
	{ href: localizePath("/loan-calculator", locale), label: t.navLoan },
	{ href: localizePath("/retirement-calculator", locale), label: t.navRetirement },
	{ href: localizePath("/tax-calculator", locale), label: t.navTax },
];
---

<!doctype html>
<html lang={meta.htmlLang}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonical} />
		{alternates.map((a) => (
			<link rel="alternate" hreflang={a.hreflang} href={a.href} />
		))}
		<link rel="alternate" hreflang="x-default" href={xDefault} />
		{noindex && <meta name="robots" content="noindex,follow" />}
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta property="og:locale" content={meta.htmlLang.replace("-", "_")} />
		<meta name="theme-color" content="#2563eb" />
		<slot name="head" />
	</head>
	<body>
		<header class="site-header">
			<div class="container">
				<a href={localizePath("/", locale)} class="brand">
					{t.brand === "FinCalc" ? <>Fin<span>Calc</span></> : t.brand}
				</a>
				<nav class="nav">
					{nav.map((n) => <a href={n.href}>{n.label}</a>)}
					<LanguagePicker barePath={path} locale={locale} />
				</nav>
			</div>
		</header>

		<main class="container">
			<slot />
		</main>

		<footer class="site-footer">
			<div class="container">
				<p class="disclaimer-foot"><strong>{t.brand}</strong> · {t.footer}</p>
				<p>
					<a href={localizePath("/", locale)}>{t.home}</a> ·
					<a href={localizePath("/privacy", locale)}>{t.privacy}</a> ·
					<a href={localizePath("/calculators/mortgage", locale)}>{t.allCalculators}</a>
				</p>
			</div>
		</footer>

		<CookieConsent locale={locale} />
		{/* Privacy-friendly analytics: record a pageview. No PII, no input values. */}
		<script>
			import { pageview } from "../lib/analytics";
			pageview();
		</script>
	</body>
</html>
